# fleet-bench — AWS deploy-profile env (R5 / G7; API-KEY-ONLY).
# ============================================================================
# Placeholders ONLY. Do NOT commit a filled-in copy. On AWS these are injected
# by the platform secrets manager (SSM Parameter Store / Secrets Manager →
# ECS task `secrets` / k8s Secret) into the SAME env var names.
# See DEPLOY_AWS.md for the parameter → env mapping.
#
# fleet-bench holds NO provider/model keys — all model auth lives in OpenRunner.
# FORBIDDEN here (subscription auth is local-dev only, and not even model-relevant
# to fleet-bench): CLAUDE_CODE_OAUTH_TOKEN, CODEX_HOME / ~/.codex, Keychain.
# ============================================================================

# ---- runner routing: the OpenRunner product path ----
# gateway = route runs through OpenRunner's agent-gateway (audit/cost/memory ownership).
RUNNER_MODE=gateway
# Configurable OpenRunner host. Default in the overlay is the in-VPC service DNS
# placeholder (openrunner.internal). Set this to your real OpenRunner gateway:
OPENRUNNER_GATEWAY_URL=http://openrunner.internal:9422
# Client token fleet-bench presents to OpenRunner's agent-gateway (an API_KEYS entry there):
OPENRUNNER_GATEWAY_TOKEN=__SSM:/fleet-bench/prod/OPENRUNNER_GATEWAY_TOKEN__

# Raw per-runner URLs (harness/debug fallback only; product uses gateway above):
RUNNER_CODEX_URL=http://openrunner.internal:9430
RUNNER_CLAUDE_URL=http://openrunner.internal:9431
RUNNER_OPENCODEX_URL=http://openrunner.internal:9432
RUNNER_MOCK_URL=http://openrunner.internal:9433

# ---- product identity (gateway-mode attribution) ----
OPENRUNNER_TENANT=default
OPENRUNNER_APP=fleet-bench
OPENRUNNER_USER=anon

# ---- backend / prompt-manager secrets ----
JWT_SECRET_KEY=__SSM:/fleet-bench/prod/JWT_SECRET_KEY__
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@fleet-bench.openli.ai
ADMIN_PASSWORD=__SSM:/fleet-bench/prod/ADMIN_PASSWORD__

# ---- database ----
# In-stack postgres uses the compose default; for RDS override (psycopg driver):
# DATABASE_URL=postgresql+psycopg://USER:PASS@your-rds-host:5432/saas
DATABASE_URL=postgresql+psycopg://saas:saas@postgres:5432/saas

# ---- evaluation (optional) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=saas-codex
